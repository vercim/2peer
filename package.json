{
  "name": "2peer",
  "version": "1.0.8",
  "description": "2peer",
  "type": "module",
  "main": "src/electron.cjs",
  "scripts": {
    "prebuild:win": "node -e \"const p=require('./package.json');p.version=p.version.replace(/(\\d+\\.\\d+\\.)(\\d+)/,(m,m1,m2)=>m1+(+m2+1));require('fs').writeFileSync('package.json',JSON.stringify(p,null,2))\"",
    "prebuild:mac": "node -e \"const p=require('./package.json');p.version=p.version.replace(/(\\d+\\.\\d+\\.)(\\d+)/,(m,m1,m2)=>m1+(+m2+1));require('fs').writeFileSync('package.json',JSON.stringify(p,null,2))\"",
    "start": "vite build && electron .",
    "dev": "vite",
    "build": "vite build",
    "build:win": "vite build && electron-builder --win --x64",
    "build:mac": "vite build && electron-builder --mac"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.101.1",
    "lucide-react": "^1.7.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "torph": "^0.0.9"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.2.2",
    "@tailwindcss/vite": "^4.2.2",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.27",
    "electron": "^35.0.0",
    "electron-builder": "^25.1.8",
    "postcss": "^8.5.8",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.2.2",
    "vite": "^5.1.0"
  },
  "build": {
    "appId": "dev.vercim.2peer",
    "productName": "2peer",
    "asar": true,
    "npmRebuild": false,
    "files": [
      "dist/**/*",
      "dist",
      "src/electron.cjs",
      "src/preload.cjs",
      "assets/**/*",
      "package.json"
    ],
    "mac": {
      "icon": "assets/icon.icns",
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.utilities"
    },
    "win": {
      "icon": "assets/icon.ico",
      "target": [
        "nsis"
      ]
    },
    "linux": {
      "icon": "assets/icon.png",
      "target": [
        "AppImage",
        "deb"
      ]
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico",
      "installerHeaderIcon": "assets/icon.ico",
      "license": null,
      "guid": "D6F8C64E-8A3B-4E9F-B2C1-5D7E3F9A8B2C"
    }
  },
  "author": "vercim"
}